{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "clamav",
    "expose",
    "global",
    "lidarr",
    "nas",
    "plex",
    "radarr",
    "sabnzbd",
    "seerr",
    "sonarr",
    "tautulli",
    "vpn"
  ],
  "properties": {
    "global": {
      "type": "object",
      "required": [
        "puid",
        "pgid",
        "timezone"
      ],
      "properties": {
        "puid": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "pgid": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "nas": {
      "type": "object",
      "required": [
        "host",
        "mediaShare",
        "mountOptions",
        "mediaShareSize"
      ],
      "properties": {
        "host": {
          "type": "string"
        },
        "mediaShare": {
          "type": "string",
          "minLength": 1
        },
        "mountOptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mediaShareSize": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?(Ei|Pi|Ti|Gi|Mi|Ki|E|P|T|G|M|K)?$"
        }
      }
    },
    "plex": {
      "type": "object",
      "required": [
        "image",
        "basePort",
        "replicas",
        "configStorageSize"
      ],
      "properties": {
        "image": {
          "type": "string",
          "not": {
            "pattern": ":latest$"
          }
        },
        "basePort": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "configStorageSize": {
          "type": "string"
        },
        "libraries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "type",
              "path"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": [
                  "movie",
                  "show",
                  "artist",
                  "photo"
                ]
              },
              "path": {
                "type": "string",
                "pattern": "^/"
              }
            }
          }
        }
      }
    },
    "vpn": {
      "type": "object",
      "required": [
        "image",
        "rotationIntervalSeconds",
        "firewallOutboundSubnets",
        "controlAuthSecret",
        "ovpnSecret"
      ],
      "properties": {
        "image": {
          "type": "string",
          "not": {
            "pattern": ":latest$"
          }
        },
        "rotationIntervalSeconds": {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      }
    },
    "clamav": {
      "type": "object",
      "required": [
        "enabled",
        "image"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "image": {
          "type": "string",
          "not": {
            "pattern": ":latest$"
          }
        }
      }
    },
    "expose": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "nodePort",
            "loadBalancer",
            "clusterIP"
          ]
        },
        "nodePorts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 30000,
            "maximum": 32767
          }
        }
      }
    },
    "sabnzbd": {
      "type": "object",
      "properties": {
        "config": {
          "type": "object",
          "properties": {
            "seed": {
              "type": "boolean"
            },
            "enableHttps": {
              "type": "boolean"
            },
            "inetExposure": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "hostWhitelist": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "downloads": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "size": {
              "type": "string"
            },
            "completeDir": {
              "type": "string",
              "pattern": "^/"
            },
            "incompleteDir": {
              "type": "string",
              "pattern": "^/"
            }
          }
        }
      }
    },
    "backup": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "image": {
          "type": "string",
          "not": {
            "pattern": ":latest$"
          }
        },
        "schedule": {
          "type": "string",
          "minLength": 9
        },
        "destination": {
          "type": "string",
          "pattern": "^/"
        },
        "keep": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "apps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scratchSize": {
          "type": "string",
          "pattern": "^[0-9]+(Ei|Pi|Ti|Gi|Mi|Ki)?$"
        }
      }
    },
    "prowlarr": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "image": {
          "type": "string",
          "not": {
            "pattern": ":latest$"
          }
        },
        "port": {
          "type": "integer"
        }
      }
    },
    "autowire": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}